# 直邮管家 ZYGJ — 环境变量模板
# 复制为 .env 并填入实际值

# 聚水潭 API 配置（必填）
JST_APP_KEY=your_app_key_here
JST_APP_SECRET=your_app_secret_here
JST_TOKEN=your_token_here

# 货易达登录凭据（必填，轨迹查询用）
HEUTE_USERNAME=USTAR
HEUTE_PASSWORD=your_password_here

# 轨迹查询系统密码（必填，track.heute-express.com）
TRACK_USERNAME=admin
TRACK_PASSWORD=your_track_password_here

# 身份证认证系统密钥（必填，ccs.ustarvs.com）
IDCARD_APP_KEY=your_base64_key_here

# Flask secret key（可选，自动生成）
FLASK_SECRET_KEY=

# 端口（默认 8899）
ZYGJ_PORT=8899

# 调试模式（默认 false）
ZYGJ_DEBUG=false
